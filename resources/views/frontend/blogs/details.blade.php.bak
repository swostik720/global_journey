    {{-- ═══════════════════════════════════════════════════════════
         ALL STYLES  (scoped with bds- prefix to avoid conflicts)
    ═══════════════════════════════════════════════════════════ --}}
    <style>
        /* ─── Reset / Base ────────────────────────────────────────── */
        *, *::before, *::after { box-sizing: border-box; }

        /* Force Poppins throughout the blog detail page */
        .bds-hero,
        .bds-main,
        .bds-related,
        .bds-hero *,
        .bds-main *,
        .bds-related * {
            font-family: "Poppins", sans-serif !important;
        }

        /* ─── Hero ────────────────────────────────────────────────── */
        .bds-hero {
            position: relative;
            background-size: cover;
            background-position: center;
            padding: 80px 0 100px;
            min-height: 480px;
            display: flex;
            align-items: center;
        }
        .bds-hero .container { width: 100%; }
        .bds-hero__overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(100deg, rgba(5,20,60,0.72) 0%, rgba(10,35,90,0.45) 55%, rgba(5,18,55,0.65) 100%);
        }
        .bds-hero .container { position: relative; z-index: 1; }
        .bds-hero__inner { padding-left: 40px; }

        .bds-hero__title {
            font-size: clamp(36px, 5vw, 64px);
            font-weight: 800;
            line-height: 1.1;
            letter-spacing: -0.02em;
            color: #f0f8ff;
            text-shadow: 0 4px 18px rgba(0,15,50,0.4);
            margin: 0 0 18px;
            text-wrap: balance;
        }
        .bds-hero__title-main { display: inline; }
        .bds-hero__title-accent {
            display: inline;
            background: linear-gradient(90deg, #93e8ff 0%, #60d4ff 45%, #b3c8ff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .bds-hero__breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            color: rgba(220,235,255,0.75);
        }
        .bds-hero__breadcrumb a {
            color: rgba(220,235,255,0.85);
            text-decoration: none;
            transition: color 0.2s;
        }
        .bds-hero__breadcrumb a:hover { color: #fff; }
        .bds-hero__breadcrumb span:last-child { color: #a8c8ff; }

        /* ─── Main section ────────────────────────────────────────── */
        .bds-main {
            padding: 48px 0 64px;
            background: #f4f7fb;
        }

        /* ─── 3-column layout ─────────────────────────────────────── */
        .bds-layout {
            display: grid;
            grid-template-columns: 240px minmax(0, 1fr) 260px;
            gap: 28px;
            align-items: start;
        }
        .bds-layout--no-toc {
            grid-template-columns: minmax(0, 1fr) 260px;
        }

        /* ─── TOC column ──────────────────────────────────────────── */
        .bds-toc-col {
            /* The sticky wrapper */
            position: sticky;
            top: 24px;
            max-height: calc(100vh - 48px);
            overflow-y: auto;
            scrollbar-width: none;
        }
        .bds-toc-col::-webkit-scrollbar { display: none; }

        .bds-toc {
            background: #fff;
            border: 1px solid #e2e8f3;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 14px rgba(10,30,80,0.07);
            transition: transform 0.22s ease, box-shadow 0.22s ease;
        }
        .bds-toc:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 24px rgba(10,30,80,0.12);
        }
        .bds-toc__head {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            background: #f7faff;
            border-bottom: 1px solid #e9eef8;
        }
        .bds-toc__icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1e40af, #4f46e5);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 15px;
            flex-shrink: 0;
        }
        .bds-toc__title {
            font-size: 14px;
            font-weight: 700;
            color: #1e293b;
            line-height: 1;
        }
        .bds-toc__sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 3px;
        }

        .bds-toc__list {
            list-style: none;
            margin: 0;
            padding: 10px 0;
        }
        .bds-toc__item { margin: 0; }
        .bds-toc__link {
            display: flex;
            align-items: flex-start;
            gap: 9px;
            padding: 7px 16px;
            font-size: 12.5px;
            font-weight: 500;
            color: #64748b;
            text-decoration: none;
            border-left: 2px solid transparent;
            transition: all 0.18s ease;
            line-height: 1.4;
        }
        .bds-toc__link:hover,
        .bds-toc__link.is-active {
            color: #1e3a8a;
            border-left-color: #3b82f6;
            background: #f0f6ff;
        }
        .bds-toc__dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
            margin-top: 4px;
        }
        .bds-toc__dot--1 { background: #3b82f6; }
        .bds-toc__dot--2 { background: #7c3aed; }
        .bds-toc__dot--3 { background: #db2777; }

        .bds-toc__item--l3 .bds-toc__link,
        .bds-toc__item--l4 .bds-toc__link,
        .bds-toc__item--l5 .bds-toc__link,
        .bds-toc__item--l6 .bds-toc__link {
            padding-left: 28px;
            font-size: 11.5px;
            font-weight: 400;
        }

        /* ─── Article card ────────────────────────────────────────── */
        .bds-article {
            background: #fff;
            border: 1px solid #e2e8f3;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(10,30,80,0.07);
            transition: transform 0.24s ease, box-shadow 0.24s ease;
        }
        .bds-article:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(10,30,80,0.12);
        }

        /* Meta bar */
        .bds-meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 10px;
            padding: 14px 22px;
            background: #f7faff;
            border-bottom: 1px solid #e9eef8;
            border-left: 4px solid #1e40af;
        }
        .bds-meta__author {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .bds-meta__avatar {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: linear-gradient(135deg, #1e40af, #4f46e5);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            flex-shrink: 0;
        }
        .bds-meta__name {
            font-size: 13.5px;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.2;
        }
        .bds-meta__name--link {
            text-decoration: none;
            display: inline-block;
            transition: color 0.2s ease, transform 0.2s ease;
        }
        .bds-meta__name--link:hover {
            color: #1d4ed8;
            transform: translateX(1px);
        }
        .bds-meta__role {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 2px;
        }
        .bds-meta__chips {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }
        .bds-chip {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 11.5px;
            color: #475569;
            background: #fff;
            border: 1px solid #e2e8f0;
            padding: 4px 11px;
            border-radius: 20px;
            transition: all 0.2s ease;
        }
        .bds-chip:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(30,64,175,0.12);
            border-color: #bfdbfe;
        }
        .bds-chip i { font-size: 11px; }
        .bds-chip--cat {
            color: #1e40af;
            background: #eff6ff;
            border-color: #bfdbfe;
            font-weight: 500;
        }

        /* Reading progress */
        .bds-progress-wrap {
            height: 3px;
            background: #eef2ff;
            margin: 0;
        }
        .bds-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #3b82f6, #8b5cf6);
            width: 0%;
            transition: width 0.15s linear;
        }

        /* Featured image */
        .bds-featured-img {
            width: 100%;
            overflow: hidden;
        }
        .bds-featured-img img {
            width: 100%;
            height: 360px;
            object-fit: cover;
            display: block;
            border-bottom: 1px solid #e9eef8;
        }

        .bds-voice {
            border-radius: 12px;
            padding: 16px;
            background: linear-gradient(105deg, #b80f44 0%, #7a145f 45%, #1e22be 100%);
            margin: 18px 30px;
            color: #fff;
        }
        .bds-voice__title {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 12px;
        }
        .bds-voice__title span {
            font-weight: 500;
            color: rgba(255,255,255,0.9);
            margin-left: 6px;
        }
        .bds-voice__controls {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .bds-voice__play {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: none;
            background: #4f8dff;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }
        .bds-voice__time,
        .bds-voice__total {
            font-size: 12px;
            min-width: 36px;
            color: #fff;
            font-weight: 500;
        }
        .bds-voice__progress,
        .bds-voice__volume {
            -webkit-appearance: none;
            appearance: none;
            height: 4px;
            background: rgba(255,255,255,0.4);
            border-radius: 999px;
            outline: none;
        }
        .bds-voice__progress { flex: 1; }
        .bds-voice__volume { width: 90px; }
        .bds-voice__progress::-webkit-slider-thumb,
        .bds-voice__volume::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            background: #ff3b30;
            cursor: pointer;
        }
        .bds-voice__rate {
            border: none;
            border-radius: 8px;
            padding: 6px 8px;
            background: rgba(255,255,255,0.24);
            color: #fff;
            font-weight: 600;
            font-size: 13px;
        }
        .bds-voice__vol-icon {
            color: rgba(255,255,255,0.95);
        }

        /* Prose / body */
        .bds-prose {
            padding: 28px 30px;
            font-size: 15.5px;
            line-height: 1.85;
            color: #374151;
        }

        .bds-mid-section {
            margin: 1.75rem 0 1.9rem;
            border: 1px solid #d3deef;
            border-radius: 14px;
            background: linear-gradient(180deg, #eef4ff 0%, #e8effb 100%);
            padding: 18px;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
        }

        .bds-mid-section__title {
            font-size: 1.08rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 14px;
        }

        .bds-quickinfo__grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 10px;
        }

        .bds-quickinfo__card {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            background: #f7f9ff;
            border: 1px solid #dbe4f5;
            border-radius: 10px;
            padding: 10px;
            min-height: 100%;
            transition: all 0.2s ease;
        }

        .bds-quickinfo__card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 16px rgba(29, 78, 216, 0.12);
        }

        .bds-quickinfo__icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: linear-gradient(135deg, #2349b7, #4458d8);
            color: #fff;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
        }

        .bds-quickinfo__content h3 {
            margin: 0 0 2px;
            font-size: 0.92rem;
            font-weight: 700;
            color: #0f172a;
        }

        .bds-quickinfo__content p {
            margin: 0;
            font-size: 0.84rem;
            line-height: 1.5;
            color: #475569;
        }

        .bds-highlights__list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 10px;
        }

        .bds-highlights__list li {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            color: #1e293b;
            line-height: 1.7;
            padding: 12px 14px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.92);
            border: 1px solid #dde6f5;
        }

        .bds-highlights__icon {
            color: #2563eb;
            font-size: 20px;
            line-height: 1;
            margin-top: 2px;
            flex-shrink: 0;
        }
        .bds-prose p {
            margin-bottom: 1.2rem;
            text-align: justify;
        }
        .bds-prose h1,
        .bds-prose h2 {
            font-size: 1.2rem;
            font-weight: 700;
            color: #0f172a;
            margin: 2rem 0 0.85rem;
            padding-bottom: 8px;
            border-bottom: 1px solid #f1f5f9;
            scroll-margin-top: 30px;
        }
        .bds-prose h3 {
            font-size: 1.05rem;
            font-weight: 700;
            color: #1e293b;
            margin: 1.6rem 0 0.75rem;
            scroll-margin-top: 30px;
        }
        .bds-prose h4,
        .bds-prose h5,
        .bds-prose h6 {
            font-size: 0.95rem;
            font-weight: 700;
            color: #334155;
            margin: 1.3rem 0 0.6rem;
            scroll-margin-top: 30px;
        }
        .bds-prose ul,
        .bds-prose ol {
            padding-left: 1.5rem;
            margin-bottom: 1.3rem;
            color: #374151;
        }
        .bds-prose li { margin-bottom: 0.5rem; }
        .bds-prose blockquote {
            background: #f8faff;
            border-left: 3px solid #3b82f6;
            border-radius: 0 10px 10px 0;
            padding: 14px 20px;
            margin: 1.8rem 0;
            font-style: italic;
            color: #475569;
            font-size: 0.98rem;
            line-height: 1.7;
        }
        .bds-prose img {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            margin: 1.5rem 0;
            box-shadow: 0 6px 20px rgba(10,30,80,0.1);
            border: 1px solid #e2e8f3;
        }
        .bds-prose table {
            width: 100%;
            border-collapse: collapse;
            margin: 1.6rem 0;
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #e2eaf8;
            font-size: 14px;
        }
        .bds-prose table th {
            background: #f0f6ff;
            font-weight: 700;
            color: #1e3a8a;
            padding: 10px 14px;
            text-align: left;
            border-bottom: 1px solid #dde9f8;
        }
        .bds-prose table td {
            padding: 9px 14px;
            border-bottom: 1px solid #eef2fb;
            color: #374151;
        }
        .bds-prose table tr:last-child td { border-bottom: none; }
        .bds-prose code {
            background: #eff6ff;
            color: #1d4ed8;
            font-size: 0.88em;
            padding: 2px 7px;
            border-radius: 5px;
        }
        .bds-prose pre {
            background: #0f172a;
            color: #e2e8f0;
            border-radius: 10px;
            padding: 1rem 1.2rem;
            overflow-x: auto;
            margin: 1.5rem 0;
            font-size: 0.88rem;
        }
        .bds-prose pre code { background: none; color: inherit; padding: 0; }
        .bds-prose a {
            color: #1d4ed8;
            text-decoration: underline;
            text-underline-offset: 3px;
        }
        .bds-prose a:hover { color: #1e3a8a; }

        /* FAQ section */
        .bds-faq {
            margin: 0 30px 28px;
            padding: 24px;
            background: #f7faff;
            border-radius: 14px;
            border: 1px solid #dde9f8;
        }
        .bds-faq__heading {
            font-size: 1.1rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .bds-faq__heading i { color: #1d4ed8; }
        .bds-faq__item {
            border: 1px solid #e2eaf8;
            border-radius: 10px;
            overflow: hidden;
            margin-bottom: 10px;
            background: #fff;
            transition: box-shadow 0.2s;
        }
        .bds-faq__item:last-child { margin-bottom: 0; }
        .bds-faq__item:hover { box-shadow: 0 4px 14px rgba(30,58,138,0.08); }
        .bds-faq__btn {
            font-weight: 600;
            font-size: 14px;
            color: #1e3a8a;
            background: #fff;
            padding: 14px 16px;
        }
        .bds-faq__btn:not(.collapsed) {
            background: #eff6ff;
            color: #1d4ed8;
        }
        .bds-faq__btn:focus { box-shadow: none; }
        .bds-faq__body {
            font-size: 14px;
            color: #475569;
            line-height: 1.7;
            background: #f8faff;
            padding: 14px 18px;
        }

        /* Stats strip */
        .bds-stats {
            display: flex;
            border-top: 1px solid #f1f5f9;
            border-bottom: 1px solid #f1f5f9;
        }
        .bds-stats__cell {
            flex: 1;
            padding: 13px 10px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            border-right: 1px solid #f1f5f9;
            cursor: default;
            background: none;
        }
        .bds-stats__cell:last-child { border-right: none; }
        .bds-stats__cell--btn {
            cursor: pointer;
            border: none;
            transition: background 0.18s;
        }
        .bds-stats__cell--btn:hover {
            background: #f0f6ff;
        }
        .bds-stats__cell--btn:hover .bds-stats__icon {
            color: #1d4ed8;
        }
        .bds-stats__num {
            font-size: 15px;
            font-weight: 700;
            color: #1e293b;
        }
        .bds-stats__icon {
            font-size: 17px;
            color: #64748b;
        }
        .bds-stats__lbl {
            font-size: 11px;
            color: #94a3b8;
        }

        /* Prev/Next nav */
        .bds-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 20px 28px;
        }
        .bds-nav__btn {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border: 1px solid #e2e8f3;
            border-radius: 11px;
            background: #f8faff;
            text-decoration: none;
            color: #374151;
            transition: all 0.2s;
            max-width: 46%;
            font-size: 13px;
        }
        .bds-nav__btn:hover {
            background: #fff;
            border-color: #93c5fd;
            color: #1e3a8a;
            box-shadow: 0 4px 14px rgba(59,130,246,0.1);
            transform: translateY(-1px);
        }
        .bds-nav__btn i {
            font-size: 20px;
            color: #3b82f6;
            flex-shrink: 0;
        }
        .bds-nav__btn--next { flex-direction: row; }
        .bds-nav__btn--next > div { text-align: right; }
        .bds-nav__label {
            display: block;
            font-size: 10.5px;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .bds-nav__title {
            display: block;
            font-weight: 600;
            font-size: 12.5px;
            color: #1e293b;
            margin-top: 2px;
        }

        .bds-back {
            padding: 0 28px 24px;
            text-align: left;
        }

        /* ─── Sidebar column ──────────────────────────────────────── */
        .bds-sidebar-col {
            position: sticky;
            top: 24px;
            max-height: calc(100vh - 48px);
            overflow-y: auto;
            scrollbar-width: none;
        }
        .bds-sidebar-col::-webkit-scrollbar { display: none; }

        .bds-sidebar {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        /* CTA card */
        .bds-cta {
            border-radius: 16px;
            padding: 22px 20px;
            background: linear-gradient(155deg, #0f2460 0%, #1d4ed8 55%, #4338ca 100%);
            color: #fff;
            box-shadow: 0 10px 28px rgba(15,36,96,0.28);
            border: 1px solid rgba(255,255,255,0.12);
            transition: transform 0.24s ease, box-shadow 0.24s ease;
        }
        .bds-cta:hover {
            transform: translateY(-3px);
            box-shadow: 0 16px 34px rgba(15,36,96,0.34);
        }
        .bds-cta__tag {
            display: inline-block;
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            background: rgba(255,255,255,0.16);
            border-radius: 20px;
            padding: 4px 12px;
            margin-bottom: 14px;
        }
        .bds-cta__title {
            font-size: 1.2rem;
            font-weight: 700;
            line-height: 1.3;
            color: #fff;
            margin-bottom: 10px;
        }
        .bds-cta__body {
            font-size: 12.5px;
            line-height: 1.65;
            color: rgba(255,255,255,0.82);
            margin-bottom: 18px;
        }
        .bds-cta__actions { display: flex; flex-direction: column; gap: 9px; }
        .bds-cta__btn {
            display: block;
            text-align: center;
            border-radius: 10px;
            padding: 11px 12px;
            font-size: 12.5px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.18s;
        }
        .bds-cta__btn--primary {
            background: #fff;
            color: #1e3a8a;
        }
        .bds-cta__btn--primary:hover { background: #eff6ff; color: #1e3a8a; }
        .bds-cta__btn--outline {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.3);
        }
        .bds-cta__btn--outline:hover { background: rgba(255,255,255,0.2); color: #fff; }

        /* Subscribe card */
        .bds-subscribe {
            border-radius: 16px;
            background: #fff;
            border: 1px solid #e2e8f3;
            padding: 20px;
            box-shadow: 0 2px 12px rgba(10,30,80,0.06);
            text-align: center;
            transition: transform 0.24s ease, box-shadow 0.24s ease;
        }
        .bds-subscribe:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 28px rgba(10,30,80,0.12);
        }
        .bds-subscribe__icon-wrap {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: #eff6ff;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
        }
        .bds-subscribe__icon {
            font-size: 20px;
            color: #1d4ed8;
        }
        .bds-subscribe__title {
            font-size: 1rem;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 6px;
        }
        .bds-subscribe__body {
            font-size: 12px;
            color: #64748b;
            line-height: 1.55;
            margin-bottom: 16px;
        }
        .bds-subscribe__form {
            display: flex;
            flex-direction: column;
            gap: 9px;
        }
        .bds-subscribe__form input {
            width: 100%;
            padding: 9px 13px;
            border: 1px solid #e2e8f0;
            border-radius: 9px;
            font-size: 13px;
            color: #1e293b;
            background: #f8faff;
            outline: none;
            transition: border-color 0.18s;
        }
        .bds-subscribe__form input:focus { border-color: #93c5fd; }
        .bds-subscribe__form button {
            width: 100%;
            padding: 10px;
            border-radius: 9px;
            background: linear-gradient(90deg, #1e40af, #4f46e5);
            color: #fff;
            font-size: 13px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            transition: opacity 0.18s;
        }
        .bds-subscribe__form button:hover { opacity: 0.88; }

        .bds-enroll {
            background: #fff;
            border: 1px solid #e2e8f3;
            border-radius: 16px;
            box-shadow: 0 2px 14px rgba(10,30,80,0.07);
            padding: 18px;
        }

        .bds-enroll__title {
            margin: 0 0 6px;
            font-size: 1.2rem;
            color: #0f172a;
            font-weight: 700;
        }

        .bds-enroll__sub {
            font-size: 13px;
            color: #64748b;
            margin: 0 0 12px;
            line-height: 1.6;
        }

        /* ─── Related posts ───────────────────────────────────────── */
        .bds-related {
            padding: 60px 0 72px;
            background: #f4f7fb;
            border-top: 1px solid #e2e8f3;
        }
        .bds-related__head { text-align: center; margin-bottom: 36px; }
        .bds-related__heading {
            font-size: 2rem;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 6px;
        }
        .bds-related__sub {
            font-size: 14px;
            color: #64748b;
            margin-bottom: 10px;
        }
        .bds-related__line { display: block; margin: 0 auto; }

        .bds-related .themebtu {
            width: 100%;
            text-align: center;
            display: inline-block;
            margin-top: 10px;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .bds-related .themebtu:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 20px rgba(0,73,255,0.16);
        }

        .bds-related__author-link {
            color: #475569;
            text-decoration: none;
            transition: color 0.2s ease;
        }
        .bds-related__author-link:hover {
            color: #1d4ed8;
        }

        .bds-related .blog-card-link {
            text-decoration: none;
            color: inherit;
        }
        .bds-related .blog-card {
            transition: transform 0.28s ease, box-shadow 0.28s ease;
        }
        .bds-related .blog-card:hover {
            transform: translateY(-7px);
            box-shadow: 0 16px 34px rgba(10,30,80,0.16);
        }
        .bds-related .card-img-top {
            transition: transform 0.4s ease;
        }
        .bds-related .blog-card:hover .card-img-top {
            transform: scale(1.05);
        }
        .bds-related__grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 24px;
        }

        /* Related card */
        .bds-rcard {
            background: #fff;
            border: 1px solid #e2e8f3;
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transition: transform 0.25s, box-shadow 0.25s;
        }
        .bds-rcard:hover {
            transform: translateY(-5px);
            box-shadow: 0 14px 32px rgba(10,30,80,0.12);
        }
        .bds-rcard__img-wrap { overflow: hidden; height: 190px; }
        .bds-rcard__img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
        }
        .bds-rcard:hover .bds-rcard__img { transform: scale(1.04); }
        .bds-rcard__body {
            padding: 18px 18px 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }
        .bds-rcard__cat {
            display: inline-block;
            font-size: 10.5px;
            font-weight: 600;
            color: #1e40af;
            background: #eff6ff;
            border: 1px solid #bfdbfe;
            padding: 3px 10px;
            border-radius: 20px;
            margin-bottom: 10px;
        }
        .bds-rcard__title {
            font-size: 14.5px;
            font-weight: 700;
            color: #0f172a;
            line-height: 1.4;
            margin-bottom: 8px;
        }
        .bds-rcard__excerpt {
            font-size: 12.5px;
            color: #64748b;
            line-height: 1.6;
            margin-bottom: 14px;
            flex: 1;
        }
        .bds-rcard__footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding-top: 12px;
            border-top: 1px solid #f1f5f9;
        }
        .bds-rcard__date {
            font-size: 11px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .bds-rcard__link {
            font-size: 12px;
            font-weight: 600;
            color: #1d4ed8;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: gap 0.18s;
        }
        .bds-rcard__link:hover { gap: 8px; color: #1e3a8a; }

        /* ─── Responsive ──────────────────────────────────────────── */
        @media (max-width: 1100px) {
            .bds-layout {
                grid-template-columns: 210px minmax(0,1fr) 230px;
            }

            .bds-quickinfo__grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 900px) {
            .bds-layout {
                grid-template-columns: 1fr;
            }
            .bds-toc-col,
            .bds-sidebar-col {
                position: static;
                max-height: none;
                overflow-y: visible;
            }
            /* On mobile, show TOC and Sidebar above & below article */
            .bds-toc-col { order: -1; }
            .bds-article { order: 0; }
            .bds-sidebar-col { order: 1; }
            .bds-hero__inner { padding-left: 10px; }
            .bds-featured-img img { height: 240px; }
            .bds-voice { margin: 16px 18px; }
            .bds-prose { padding: 20px 18px; }
            .bds-faq { margin: 0 18px 20px; }
            .bds-nav { flex-direction: column; align-items: stretch; }
            .bds-nav__btn { max-width: 100%; }
            .bds-quickinfo__grid { grid-template-columns: 1fr; }
        }

        @media (max-width: 576px) {
            .bds-hero { padding: 60px 0 70px; }
            .bds-main { padding: 28px 0 40px; }
            .bds-meta { flex-direction: column; align-items: flex-start; }
            .bds-voice__controls {
                flex-wrap: wrap;
                gap: 8px;
            }
            .bds-voice__progress {
                order: 3;
                width: calc(100% - 56px);
                flex: none;
            }
        }
    </style>

    {{-- ═══════════════════════════════════════════════════════════
         SCRIPTS
    ═══════════════════════════════════════════════════════════ --}}
    <script>
    document.addEventListener('DOMContentLoaded', function () {

        /* ── Reading progress bar ── */
        var progressFill = document.getElementById('bdsProgress');
        var article      = document.querySelector('.bds-article');
        if (progressFill && article) {
            window.addEventListener('scroll', function () {
                var rect  = article.getBoundingClientRect();
                var total = article.offsetHeight - window.innerHeight;
                var done  = Math.max(0, -rect.top);
                progressFill.style.width = Math.min(100, (done / total) * 100) + '%';
            }, { passive: true });
        }

        /* ── Estimated read time ── */
        var readTimeEl = document.getElementById('bdsReadTime');
        var prose      = document.querySelector('.bds-prose');
        if (readTimeEl && prose) {
            var words   = prose.innerText.trim().split(/\s+/).length;
            var minutes = Math.max(1, Math.ceil(words / 220));
            readTimeEl.textContent = minutes;
        }

        /* ── TOC active-link highlighting (IntersectionObserver) ── */
        var tocLinks = document.querySelectorAll('.bds-toc__link');
        if (tocLinks.length) {
            var headings = Array.from(document.querySelectorAll('.bds-prose h1, .bds-prose h2, .bds-prose h3, .bds-prose h4, .bds-prose h5, .bds-prose h6'));

            var observer = new IntersectionObserver(function (entries) {
                entries.forEach(function (entry) {
                    if (entry.isIntersecting) {
                        tocLinks.forEach(function (l) { l.classList.remove('is-active'); });
                        var active = document.querySelector('.bds-toc__link[data-toc-id="' + entry.target.id + '"]');
                        if (active) {
                            active.classList.add('is-active');
                            /* Scroll the TOC so active item is visible */
                            var tocCol = document.querySelector('.bds-toc-col');
                            if (tocCol) {
                                var linkTop    = active.offsetTop;
                                var colScroll  = tocCol.scrollTop;
                                var colHeight  = tocCol.clientHeight;
                                if (linkTop < colScroll || linkTop > colScroll + colHeight - 40) {
                                    tocCol.scrollTo({ top: linkTop - colHeight / 2, behavior: 'smooth' });
                                }
                            }
                        }
                    }
                });
            }, { rootMargin: '0px 0px -60% 0px', threshold: 0 });

            headings.forEach(function (h) { if (h.id) observer.observe(h); });
        }

        /* ── Share button ── */
        var shareBtn = document.getElementById('bdsShareBtn');
        if (shareBtn) {
            shareBtn.addEventListener('click', function () {
                if (navigator.share) {
                    navigator.share({ title: document.title, url: window.location.href });
                } else {
                    navigator.clipboard.writeText(window.location.href).then(function () {
                        shareBtn.querySelector('.bds-stats__lbl').textContent = 'Copied!';
                        setTimeout(function () {
                            shareBtn.querySelector('.bds-stats__lbl').textContent = 'Share';
                        }, 2000);
                    });
                }
            });
        }

        /* ── Print article only ── */
        window.bdsPrintArticle = function () {
            var article = document.querySelector('.bds-article');
            if (!article) { window.print(); return; }
            var printWindow = window.open('', '_blank', 'width=900,height=700');
            var styles = Array.from(document.querySelectorAll('link[rel="stylesheet"], style'))
                .map(function (el) { return el.outerHTML; }).join('\n');
            printWindow.document.write(
                '<!DOCTYPE html><html><head><title>' + document.title + '</title>' +
                styles +
                '</head><body style="padding:30px;font-family:Poppins,sans-serif">' +
                article.outerHTML +
                '</body></html>'
            );
            printWindow.document.close();
            printWindow.focus();
            printWindow.onload = function () {
                printWindow.print();
                printWindow.close();
            };
        };

        /* ── Smooth-scroll for TOC links ── */
        document.querySelectorAll('.bds-toc__link').forEach(function (link) {
            link.addEventListener('click', function (e) {
                var id = this.getAttribute('data-toc-id');
                var target = document.getElementById(id);
                if (target) {
                    e.preventDefault();
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });

        initVoicePlayer('bdsVoice', '.bds-prose');

        function initVoicePlayer(prefix, textSelector) {
            var synth = window.speechSynthesis;
            if (!synth) {
                return;
            }

            var textEl = document.querySelector(textSelector);
            var playBtn = document.getElementById(prefix + 'Play');
            var playIcon = document.getElementById(prefix + 'PlayIcon');
            var progress = document.getElementById(prefix + 'Progress');
            var timeEl = document.getElementById(prefix + 'Time');
            var totalEl = document.getElementById(prefix + 'Total');
            var rateEl = document.getElementById(prefix + 'Rate');
            var volumeEl = document.getElementById(prefix + 'Volume');

            if (!textEl || !playBtn || !playIcon || !progress || !timeEl || !totalEl || !rateEl || !volumeEl) {
                return;
            }

            var text = (textEl.innerText || '').trim();
            if (!text) {
                return;
            }

            var utterance = null;
            var isPaused = false;
            var totalSeconds = Math.max(30, Math.ceil(text.split(/\s+/).length / 160 * 60));
            totalEl.textContent = formatTime(totalSeconds);

            playBtn.addEventListener('click', function () {
                if (synth.speaking && !isPaused) {
                    synth.pause();
                    isPaused = true;
                    playIcon.className = 'bi bi-play-fill';
                    return;
                }

                if (synth.speaking && isPaused) {
                    synth.resume();
                    isPaused = false;
                    playIcon.className = 'bi bi-pause-fill';
                    return;
                }

                synth.cancel();
                utterance = new SpeechSynthesisUtterance(text);
                utterance.rate = parseFloat(rateEl.value || '1');
                utterance.volume = parseFloat(volumeEl.value || '1');

                utterance.onstart = function () {
                    playIcon.className = 'bi bi-pause-fill';
                    isPaused = false;
                };

                utterance.onboundary = function (event) {
                    if (!event || typeof event.charIndex !== 'number') {
                        return;
                    }
                    var pct = Math.min(100, (event.charIndex / text.length) * 100);
                    progress.value = pct;
                    var elapsed = Math.floor((pct / 100) * totalSeconds);
                    timeEl.textContent = formatTime(elapsed);
                };

                utterance.onend = function () {
                    playIcon.className = 'bi bi-play-fill';
                    progress.value = 100;
                    timeEl.textContent = totalEl.textContent;
                    isPaused = false;
                };

                utterance.onerror = function () {
                    playIcon.className = 'bi bi-play-fill';
                    isPaused = false;
                };

                progress.value = 0;
                timeEl.textContent = '0:00';
                synth.speak(utterance);
            });

            rateEl.addEventListener('change', function () {
                if (utterance) {
                    utterance.rate = parseFloat(rateEl.value || '1');
                }
            });

            volumeEl.addEventListener('input', function () {
                if (utterance) {
                    utterance.volume = parseFloat(volumeEl.value || '1');
                }
            });

            function formatTime(seconds) {
                var m = Math.floor(seconds / 60);
                var s = seconds % 60;
                return m + ':' + String(s).padStart(2, '0');
            }
        }

    });
    </script>

@endsection